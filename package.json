        "lint": "turbo run lint",
        "knowledge:publish": "tsx scripts/publish-knowledge.ts",
        "knowledge:sync-dell": "tsx scripts/sync-dell.ts"
    },
    "devDependencies": {
        "@inquirer/prompts": "^8.3.0",
        "tsx": "^4.21.0",
        "turbo": "latest"
    },
    "packageManager": "pnpm@10.26.1",
    "pnpm": {
        "overrides": {
            "@types/react": "^19",
            "@types/react-dom": "^19",
            "react": "^19.2.1",
            "react-dom": "^19.2.1"
        },
        "onlyBuiltDependencies": [
            "esbuild",
            "sharp",
            "unrs-resolver"
        ]
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.68.0"
    }
